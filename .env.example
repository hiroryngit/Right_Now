# ── Database (Supabase Postgres / Prisma) ──────────────────────────
# コネクションプーラ経由の接続URL（アプリ実行時に使用）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# マイグレーション用の直接接続URL（Prisma migrate で使用）
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Mapbox ─────────────────────────────────────────────────────────
# 地図表示用の公開アクセストークン
NEXT_PUBLIC_MAPBOX_TOKEN="pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Supabase ───────────────────────────────────────────────────────
# プロジェクトのURL（例: https://xxxxxxxx.supabase.co）
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# 公開用の anon キー
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ── GitHub Models API ──────────────────────────────────────────────
# AIチャット機能で使用するAPIキー
GITHUB_MODELS_API_KEY="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
